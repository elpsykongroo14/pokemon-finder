# committed on purpose (unlike .env) - this is test-only config, not a
# real secret, so it's safe to check in. Vite/Vitest automatically load
# .env.test when running in "test" mode (which vitest run uses by
# default), giving every test run - yours, a fresh clone, CI - the same
# working fake value with zero setup required.
VITE_TCG_PROXY=https://fake-proxy.test
