{
  "name": "pokemon-finder",
  "main": "src/index.js",
  "compatibility_date": "2026-07-17",

  //KV

  "kv_namespaces": [
    {
      "binding": "TCG_CACHE",
      "id": "76601004ae52446d805b797ff5c63a95",
    },
  ],

  //rate limite block:
  "unsafe": {
    "bindings": [
      {
        "name": "TCG_RATE_LIMITER",
        "type": "ratelimit",
        "namespace_id": "1001",
        "simple": { "limit": 100, "period": 60 },
      },
    ],
  },
}
